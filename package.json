{
  "name": "issuary",
  "version": "0.1.0",
  "description": "CLI to monitor and AI-compact GitHub issues across multiple repositories",
  "license": "ISC",
  "author": "Lucas Merencia <lucas.merencia@gmail.com>",
  "type": "module",
  "bin": {
    "issuary": "./dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.0.2",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "rollup": "^4.30.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merencia/issuary.git"
  },
  "homepage": "https://github.com/merencia/issuary#readme",
  "bugs": {
    "url": "https://github.com/merencia/issuary/issues"
  },
  "keywords": [
    "github",
    "issues",
    "cli",
    "monitor",
    "digest",
    "triage",
    "ai",
    "compaction",
    "repos",
    "sync"
  ]
}
